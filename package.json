{
  "name": "helloagain",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "mobile:build": "node scripts/mobile-build.mjs",
    "mobile:sync": "pnpm --filter @helloagain/web exec cap sync",
    "mobile:open:android": "pnpm --filter @helloagain/web exec cap open android",
    "mobile:open:ios": "pnpm --filter @helloagain/web exec cap open ios"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "zod": "^4.3.6"
  }
}
